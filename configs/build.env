export WORKSPACE="$PWD"
export SRC_DIR="$WORKSPACE/src"
export OUT_DIR="$WORKSPACE/out"
export SCRIPT_DIR="$WORKSPACE/scripts"
export CONFIG_DIR="$WORKSPACE/configs"

export OS_NAME="BlackholeOS"
export IMG_NAME="$OUT_DIR/blackhole-uefi.img"
export DISK_SIZE_MB=1024

export KERNEL_VER="7.0.5"
export KERNEL_URL="https://cdn.kernel.org/pub/linux/kernel/v7.x/linux-${KERNEL_VER}.tar.xz"
export KERNEL_SRC="$SRC_DIR/linux-${KERNEL_VER}"

export TOYBOX_VER="0.8.11"
export TOYBOX_URL="https://github.com/landley/toybox/archive/refs/tags/${TOYBOX_VER}.tar.gz"
export TOYBOX_SRC="$SRC_DIR/toybox-${TOYBOX_VER}"